# Copy this file to .env.local and fill in your own values.
# Never commit real cookies.

# Optional: default QQ playlist id (so CLI can omit --qq-playlist-id)
QQ_PLAYLIST_ID=

# Required for real write mode
BILI_SESSDATA=
BILI_JCT=
BILI_DEDEUSERID=

# Optional (can help with some risk-control scenes)
BILI_BUVID3=

# Optional alias, only used if BILI_DEDEUSERID is empty
# DEDEUSERID=
